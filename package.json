{
  "name": "nendplay-mobile",
  "version": "1.0.0",
  "main": "App.js",
  "scripts": {
    "start": "npx expo start",
    "start:dev": "npx expo start --dev-client",
    "admob:check": "node scripts/validate-admob-config.js",
    "build:dev:android": "npx eas-cli build --profile development --platform android",
    "build:internal:android": "npx eas-cli build --profile preview --platform android",
    "build:internal:ios": "npx eas-cli build --profile preview --platform ios",
    "build:internal:all": "npx eas-cli build --profile preview --platform all",
    "build:prod:android": "npx eas-cli build --profile production --platform android",
    "build:prod:ios": "npx eas-cli build --profile production --platform ios",
    "submit:android": "npx eas-cli submit --profile production --platform android",
    "submit:ios": "npx eas-cli submit --profile production --platform ios",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "web": "npx expo start --web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/stack": "^7.9.2",
    "axios": "^1.7.2",
    "expo": "~55.0.26",
    "expo-auth-session": "~55.0.16",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.35",
    "expo-device": "~55.0.17",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.22",
    "expo-font": "~55.0.7",
    "expo-image-picker": "~55.0.20",
    "expo-intent-launcher": "~55.0.12",
    "expo-linking": "~55.0.15",
    "expo-local-authentication": "~55.0.14",
    "expo-location": "~55.1.10",
    "expo-media-library": "~55.0.17",
    "expo-network": "~55.0.14",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-video": "~55.0.17",
    "expo-web-browser": "~55.0.16",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vector-icons": "^10.1.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^13.16.1",
    "react-native-worklets": "0.7.4",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@expo/ngrok": "^4.1.0"
  }
}
